<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- remove unused permission from AppCompat -->
    <permission
        android:name="${applicationId}.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        tools:node="remove" />

    <uses-permission
        android:name="${applicationId}.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        tools:node="remove" />

    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_REMOTE_MESSAGING" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- remove intent queries merged from library manifest (namely Android-Image-Cropper) -->
    <queries tools:node="removeAll" />

    <queries>
        <intent>
            <action android:name="${applicationId}.plugin.MANIFEST" />
        </intent>
        <!-- Compatibility with original Fcitx5 Android plugins -->
        <intent>
            <action android:name="${originalPluginManifestAction}" />
        </intent>
        <!-- Compatibility with original Fcitx5 Android debug plugins -->
        <intent>
            <action android:name="${originalDebugPluginManifestAction}" />
        </intent>
        <intent>
            <action android:name="android.view.InputMethod" />
        </intent>
    </queries>

    <permission
        android:name="${applicationId}.permission.IPC"
        android:protectionLevel="signature" />

    <permission
        android:name="${applicationId}.permission.PLUGIN"
        android:protectionLevel="signature" />

    <uses-permission android:name="${applicationId}.permission.PLUGIN" />

    <application
        android:name=".FcitxApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/full_backup_content"
        android:icon="@mipmap/app_icon"
        android:label="${appLabel}"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/app_icon_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FcitxAppTheme"
        android:usesCleartextTraffic="true"
        tools:replace="android:supportsRtl,android:networkSecurityConfig,android:usesCleartextTraffic"
        tools:targetApi="33">
        <activity
            android:name=".ui.setup.SetupActivity"
            android:exported="false"
            android:launchMode="singleTask" />
        <activity
            android:name=".ui.main.LogActivity"
            android:directBootAware="true"
            android:exported="false"
            android:launchMode="singleTask"
            android:parentActivityName=".ui.main.MainActivity" />
        <activity
            android:name=".ui.main.settings.theme.CustomThemeActivity"
            android:configChanges="orientation|screenSize"
            android:exported="false"
            android:label="@string/edit_theme" />
        <activity
            android:name=".ui.main.settings.theme.ThemeColorEditorActivity"
            android:configChanges="orientation|screenSize"
            android:exported="false"
            android:label="@string/edit_color" />
        <activity
            android:name=".ui.main.settings.theme.MonetThemeEditorActivity"
            android:configChanges="orientation|screenSize"
            android:exported="false"
            android:label="@string/edit_monet_theme" />
        <activity
            android:name=".ui.main.settings.behavior.FontsetEditorActivity"
            android:exported="false"
            android:label="@string/edit_fontset" />
        <activity
            android:name=".ui.main.settings.behavior.PopupEditorActivity"
            android:exported="false"
            android:label="@string/edit_popup_preset" />
        <activity
            android:name=".ui.main.settings.behavior.TextKeyboardLayoutEditorActivity"
            android:exported="false"
            android:label="@string/edit_text_keyboard_layout" />
        <activity
            android:name=".ui.main.settings.behavior.dialog.KeyEditorActivity"
            android:exported="false"
            android:label="@string/edit_text_keyboard_layout" />
        <activity
            android:name=".ui.main.settings.behavior.dialog.MacroEditorActivity"
            android:exported="false"
            android:label="编辑 Macro" />
        <activity
            android:name=".ui.main.settings.behavior.dialog.LayoutFileProfileInputActivity"
            android:exported="false"
            android:label="@string/edit_text_keyboard_layout" />
        <activity
            android:name=".ui.main.settings.behavior.dialog.TextKeyboardLayoutProfilePickerActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:theme="@style/Theme.TransparentOverlayActivity" />
        <activity
            android:name=".ui.main.settings.behavior.ButtonsCustomizerActivity"
            android:exported="false"
            android:label="@string/edit_buttons" />
        <activity
            android:name=".ui.main.settings.behavior.SplitKeyboardCalibrationActivity"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout"
            android:exported="false"
            android:label="@string/split_keyboard_calibration_title" />
        <activity
            android:name=".ui.main.CropImageActivity"
            android:exported="false" />
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.APPLICATION_PREFERENCES" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="file" />
                <data android:scheme="content" />
                <data android:mimeType="*/*" />
                <data android:host="*" />
                <!--
                  there has to be so many segments:
                  https://stackoverflow.com/questions/3400072/pathpattern-to-match-file-extension/8599921#8599921
                -->
                <data android:pathPattern=".*\\.dict" />
                <data android:pathPattern=".*\\..*\\.dict" />
                <data android:pathPattern=".*\\..*\\..*\\.dict" />
                <data android:pathPattern=".*\\..*\\..*\\..*\\.dict" />
                <data android:pathPattern=".*\\.scel" />
                <data android:pathPattern=".*\\..*\\.scel" />
                <data android:pathPattern=".*\\..*\\..*\\.scel" />
                <data android:pathPattern=".*\\..*\\..*\\..*\\.scel" />
                <data android:pathPattern=".*\\.txt" />
                <data android:pathPattern=".*\\..*\\.txt" />
                <data android:pathPattern=".*\\..*\\..*\\.txt" />
                <data android:pathPattern=".*\\..*\\..*\\..*\\.txt" />
                <!-- pathSuffix works on API 31+ -->
                <data android:pathSuffix=".dict" />
                <data android:pathSuffix=".scel" />
                <data android:pathSuffix=".txt" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.main.ClipboardEditActivity"
            android:autoRemoveFromRecents="true"
            android:directBootAware="true"
            android:excludeFromRecents="true"
            android:label="@string/edit_clipboard"
            android:launchMode="singleInstance"
            android:taskAffinity=".ui.main.ClipboardEditActivity"
            android:theme="@style/Theme.DialogTheme"
            android:windowSoftInputMode="stateAlwaysVisible|adjustPan" />

        <service
            android:name=".input.FcitxInputMethodService"
            android:directBootAware="true"
            android:exported="true"
            android:label="${appLabel}"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>

            <meta-data
                android:name="android.view.im"
                android:resource="@xml/input_method" />
        </service>

        <service
            android:name=".FcitxRemoteService"
            android:exported="true">
            <intent-filter>
                <action android:name="${applicationId}.IPC" />
            </intent-filter>
            <!-- Compatibility with original Fcitx5 Android plugins -->
            <intent-filter>
                <action android:name="${originalIpcAction}" />
            </intent-filter>
            <!-- Compatibility with original Fcitx5 Android debug plugins -->
            <intent-filter>
                <action android:name="${originalDebugIpcAction}" />
            </intent-filter>
        </service>

        <service
            android:name=".clipboardsync.MainService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="remoteMessaging" />

        <activity
            android:name=".clipboardsync.ui.ClipboardSyncSettingsActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.ClipboardSync.Settings" />

        <activity
            android:name=".clipboardsync.ui.ClipboardCaptureActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:finishOnTaskLaunch="true"
            android:theme="@style/Theme.ClipboardSync.Capture" />

        <service
            android:name=".clipboardsync.service.QuickSyncTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_clipboard_sync"
            android:label="@string/quick_sync_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            tools:targetApi="n">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <provider
            android:name=".provider.FcitxDataProvider"
            android:authorities="${applicationId}.provider"
            android:exported="true"
            android:grantUriPermissions="true"
            android:permission="android.permission.MANAGE_DOCUMENTS">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
            </intent-filter>
        </provider>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/clipboard_file_paths" />
        </provider>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.share.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/share_file_paths" />
        </provider>

        <!-- remove unneeded components from com.canhub.cropper -->
        <!--suppress DeprecatedClassUsageInspection -->
        <activity
            android:name="com.canhub.cropper.CropImageActivity"
            tools:node="remove" />

        <provider
            android:name="com.canhub.cropper.CropFileProvider"
            android:authorities="${applicationId}.cropper.fileprovider"
            tools:node="remove" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:directBootAware="true"
            android:exported="false"
            tools:node="merge">
            <!-- do not inject splitties AppCompat -->
            <meta-data
                android:name="splitties.views.dsl.appcompat.experimental.AppCompatViewInstantiatorInjecter"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>

</manifest>
